From 94863035bc03631402bdd1af46f60fe24276dc86 Mon Sep 17 00:00:00 2001
From: Jimmy Su <jimmy.su@intel.com>
Date: Tue, 24 Mar 2026 00:03:45 +0800
Subject: [PATCH 2/3] media: ipu-bridge: Add DMI quirk for new Dell XPS laptops
 with upside down sensors

The Dell XPS 14 DA14260 has upside down issue by mechanical design.
The rotation value should be reported by 180 degree.

Signed-off-by: Jimmy Su <jimmy.su@intel.com>

diff --git a/drivers/media/pci/intel/ipu-bridge.c b/drivers/media/pci/intel/ipu-bridge.c
index 27007327d230..f9c7ac8f4147 100644
--- a/drivers/media/pci/intel/ipu-bridge.c
+++ b/drivers/media/pci/intel/ipu-bridge.c
@@ -114,6 +114,13 @@ static const struct dmi_system_id upside_down_sensor_dmi_ids[] = {
 		},
 		.driver_data = "OVTI02C1",
 	},
+	{
+		.matches = {
+			DMI_EXACT_MATCH(DMI_SYS_VENDOR, "Dell Inc."),
+			DMI_EXACT_MATCH(DMI_PRODUCT_NAME, "XPS 14 DA14260"),
+		},
+		.driver_data = "OVTI08F4",
+	},
 	{} /* Terminating entry */
 };
 
